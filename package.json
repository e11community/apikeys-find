{
  "name": "@e11community/apikeys-find",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "apikeys-find": "./dist/cli.js"
  },
  "scripts": {
    "build:action": "esbuild src/action.ts --bundle --platform=node --target=node20 --format=cjs --minify --outfile=dist/action.js",
    "build:cli": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=cjs --minify --outfile=dist/cli.js --banner:js='#!/usr/bin/env node'",
    "build": "npm run build:action && npm run build:cli && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@google-cloud/apikeys": "^2.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
